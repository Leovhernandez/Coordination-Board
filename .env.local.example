# Coordination Board — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).

# --- Supabase (from your project's Settings → API) ---
# Safe to expose to the browser:
# URL = the BASE project url. Do NOT include a trailing /rest/v1/ (the client adds it).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# The "Publishable" key (sb_publishable_...). Legacy anon JWT (eyJ...) also works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# SECRET — server-side only. Bypasses RLS. Never expose to the browser.
# The "Secret" key (sb_secret_...). Legacy service_role JWT (eyJ...) also works.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_KEY

# --- App ---
# Used to build the texted invite links: https://<this>/j/{job_id}?t={token}
# Production: https://coordination.4lfr.com  |  Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Stripe (M8) — leave blank to run trial-only (billing disabled) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=                       # the recurring monthly Price (price_...)
NEXT_PUBLIC_PLAN_LABEL=$49/month       # display only

# --- Access ---
# "open" (anyone can request a sign-in link) or "allowlist" (only emails in the
# allowed_emails table). Defaults to open if unset.
SIGNUP_MODE=open
# Operator (vendor) admin email — unlocks the /admin page (trials, allowlist,
# company oversight) and is comped to 'active'. Set to your login email.
ADMIN_EMAIL=
