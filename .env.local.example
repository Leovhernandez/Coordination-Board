# Coordination Board — environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).

# --- Supabase (from your project's Settings → API) ---
# Safe to expose to the browser:
# URL = the BASE project url. Do NOT include a trailing /rest/v1/ (the client adds it).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# The "Publishable" key (sb_publishable_...). Legacy anon JWT (eyJ...) also works.
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# SECRET — server-side only. Bypasses RLS. Never expose to the browser.
# The "Secret" key (sb_secret_...). Legacy service_role JWT (eyJ...) also works.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_KEY

# --- App ---
# Used to build invite/sign-in links (crew links and salesman invite emails).
# Production: https://coordination.4lfr.com  |  Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Salesman invite emails (M14) ---
# Resend API key (re_...) — the SAME key you used for Supabase SMTP. Lets the app
# email an invited salesman a one-tap sign-in link. Without it, the invite row is
# still created but no email is sent.
RESEND_API_KEY=
# Sender for invite emails (must be on your Resend-verified domain).
INVITE_FROM_EMAIL=Coordination Board <noreply@4lfr.com>

# --- Stripe (M8) — leave blank to run trial-only (billing disabled) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=                       # the recurring monthly Price (price_...)
NEXT_PUBLIC_PLAN_LABEL=$49/month       # display only

# --- Access ---
# Operator (vendor) admin email — unlocks the /admin page (accounts, Owner List)
# and is comped to 'active'. Set to your login email.
# Access is always admin-gated now: only approved business owners (the Owner List
# / allowed_emails) and invited salesmen can sign in. SIGNUP_MODE is no longer used.
ADMIN_EMAIL=
